<!--管理员值班情况页面-->
<view class="container">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="header-left" bindtap="onBack">
      <text class="header-back-icon">‹</text>
    </view>
    <view class="header-center">
      <text class="header-title">值班情况</text>
    </view>
    <view class="header-right" bindtap="onClose">
      <text class="header-close-icon">×</text>
    </view>
  </view>

  <!-- 日期选择 -->
  <view class="date-bar">
    <view class="date-arrow" bindtap="prevDay">
      <text class="arrow-icon">‹</text>
    </view>
    <view class="date-text">{{displayDate}}</view>
    <view class="date-arrow" bindtap="nextDay">
      <text class="arrow-icon">›</text>
    </view>
  </view>

  <!-- 值班列表 -->
  <view class="duty-list" wx:if="{{dutyList.length > 0}}">
    <!-- 校区标题 -->
    <view class="campus-header">
      <view class="campus-map-bg"></view>
      <view class="campus-info">
        <text class="campus-name">{{campusName}}</text>
        <text class="campus-count">{{dutyList.length}}人</text>
      </view>
    </view>

    <!-- 辅导员卡片 -->
    <view class="counselor-card" wx:for="{{dutyList}}" wx:key="id">
      <view class="counselor-header">
        <view class="counselor-avatar">
          <text class="avatar-text">{{item.userName && item.userName.charAt(0) || '?'}}</text>
        </view>
        <view class="counselor-info">
          <text class="counselor-name">{{item.userName}}</text>
          <text class="counselor-id">{{item.userId}}</text>
        </view>
        <view class="phone-icon-wrap" bindtap="callPhone" data-phone="{{item.phone}}">
          <text class="phone-icon">☎</text>
        </view>
      </view>
      <view class="duty-details">
        <view class="duty-detail-item">
          <text class="detail-label">值班开始时间：</text>
          <text class="detail-value">{{item.startTime}}</text>
        </view>
        <view class="duty-detail-item">
          <text class="detail-label">值班结束时间：</text>
          <text class="detail-value">{{item.endTime}}</text>
        </view>
        <view class="duty-detail-item">
          <text class="detail-label">值班校区：</text>
          <text class="detail-value">{{item.campus}}</text>
        </view>
        <view class="duty-detail-item">
          <text class="detail-label">值班住宿地址：</text>
          <text class="detail-value">{{item.address}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty" wx:if="{{dutyList.length === 0}}">
    <view class="empty-icon-wrap">
      <text class="empty-icon">L</text>
    </view>
    <text class="empty-text">暂无值班安排</text>
  </view>

  <!-- 底部导航 -->
  <view class="tab-bar">
    <view class="tab-bar-item active">
      <view class="tab-bar-icon-wrap active">
        <text class="tab-bar-icon">📅</text>
      </view>
      <text class="tab-bar-text">值班情况</text>
    </view>
    <view class="tab-bar-item" bindtap="goToAssist">
      <view class="tab-bar-icon-wrap">
        <text class="tab-bar-icon">📋</text>
      </view>
      <text class="tab-bar-text">协助换班</text>
    </view>
    <view class="tab-bar-item" bindtap="goToMore">
      <view class="tab-bar-icon-wrap">
        <text class="tab-bar-icon">▦</text>
      </view>
      <text class="tab-bar-text">更多功能</text>
    </view>
  </view>
</view>