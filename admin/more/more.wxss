/* 管理员更多功能页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 140rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
  background-color: #fff;
}

.header-left, .header-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-back, .header-close {
  font-size: 48rpx;
  color: #333;
}

.header-center {
  flex: 1;
  text-align: center;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 功能列表 */
.function-list {
  padding: 30rpx;
}

.function-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background-color: #fef2f2;
  border-radius: 16rpx;
  margin-right: 20rpx;
}

.function-content {
  flex: 1;
}

.function-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.function-desc {
  font-size: 24rpx;
  color: #999;
}

.function-arrow {
  font-size: 32rpx;
  color: #999;
}

/* 底部导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background-color: #fff;
  padding: 20rpx 0 60rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-bar-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
}

.tab-bar-icon-wrap.active {
  background-color: #B81F24;
  border-radius: 12rpx;
}

.tab-bar-icon {
  font-size: 32rpx;
}

.tab-bar-icon-wrap.active .tab-bar-icon {
  color: #fff;
}

.tab-bar-text {
  font-size: 22rpx;
  color: #999;
}

.tab-bar-item.active .tab-bar-text {
  color: #B81F24;
}