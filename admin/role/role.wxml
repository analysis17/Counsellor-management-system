<!--管理员角色切换页面-->
<view class="container">
  <view class="header">
    <view class="header-left" bindtap="onBack">
      <text class="header-back">‹</text>
    </view>
    <view class="header-center">
      <text class="header-title">角色切换</text>
    </view>
    <view class="header-right" bindtap="onClose">
      <text class="header-close">×</text>
    </view>
  </view>

  <view class="role-list">
    <view class="role-item" bindtap="switchRole" data-role="COUNSELOR">
      <view class="role-radio {{currentRole === 'COUNSELOR' ? 'checked' : ''}}">
        <view class="radio-inner" wx:if="{{currentRole === 'COUNSELOR'}}"></view>
      </view>
      <text class="role-text">发展辅导员角色</text>
    </view>

    <view class="role-item" bindtap="switchRole" data-role="COLLEGE">
      <view class="role-radio {{currentRole === 'COLLEGE' ? 'checked' : ''}}">
        <view class="radio-inner" wx:if="{{currentRole === 'COLLEGE'}}"></view>
      </view>
      <text class="role-text">发展学院角色</text>
    </view>

    <view class="role-item" bindtap="switchRole" data-role="ADMIN">
      <view class="role-radio {{currentRole === 'ADMIN' ? 'checked' : ''}}">
        <view class="radio-inner" wx:if="{{currentRole === 'ADMIN'}}"></view>
      </view>
      <text class="role-text">发展管理员角色</text>
    </view>
  </view>
</view>