/* 辅导员值班历史页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
  background-color: #fff;
}

.header-left, .header-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-back-icon, .header-close-icon {
  font-size: 48rpx;
  color: #333;
}

.header-center {
  flex: 1;
  text-align: center;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 时间筛选 */
.filter-bar {
  padding: 24rpx 30rpx;
  background-color: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.filter-select {
  display: flex;
  align-items: center;
  width: 180rpx;
  padding: 18rpx 24rpx;
  background-color: #fff;
  border-radius: 8rpx;
  border: 1rpx solid #ddd;
}

.filter-text {
  font-size: 28rpx;
  color: #333;
}

.filter-arrow {
  font-size: 22rpx;
  color: #999;
  margin-left: 12rpx;
}

/* 历史列表 */
.history-list {
  padding: 30rpx;
}

.history-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.history-date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.history-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.history-type {
  font-size: 24rpx;
  color: #fff;
  background-color: #B81F24;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.history-info-item {
  display: flex;
  margin-bottom: 14rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  width: 200rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}
