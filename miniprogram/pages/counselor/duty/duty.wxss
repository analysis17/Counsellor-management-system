/* 辅导员值班安排页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
  background-color: #fff;
}

.header-left, .header-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-back-icon, .header-close-icon {
  font-size: 48rpx;
  color: #333;
}

.header-center {
  flex: 1;
  text-align: center;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 值班列表 */
.duty-list {
  padding: 30rpx;
}

.duty-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.duty-date-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.duty-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.duty-type {
  font-size: 24rpx;
  color: #fff;
  background-color: #B81F24;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.duty-info-item {
  display: flex;
  margin-bottom: 16rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  width: 200rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.duty-footer {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: right;
}

.btn-exchange {
  font-size: 26rpx;
  color: #B81F24;
}

.duty-status-bar {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 16rpx;
  background-color: #fff3e8;
  border-radius: 8rpx;
}

.status-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.status-text {
  font-size: 24rpx;
  color: #E6A23C;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon-wrap {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon {
  position: relative;
  width: 150rpx;
  height: 150rpx;
}

.icon-paper {
  position: absolute;
  width: 120rpx;
  height: 100rpx;
  background-color: #e8e8e8;
  border-radius: 8rpx;
  top: 20rpx;
  left: 15rpx;
}

.icon-l {
  position: absolute;
  width: 60rpx;
  height: 60rpx;
  background-color: #B81F24;
  border-radius: 50%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  top: 50rpx;
  left: 45rpx;
  z-index: 1;
}

.icon-line {
  position: absolute;
  width: 60rpx;
  height: 4rpx;
  background-color: #333;
  top: 80rpx;
  left: 20rpx;
  transform: rotate(-20deg);
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 底部导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background-color: #fff;
  padding: 20rpx 0;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-bar-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  border-radius: 12rpx;
}

.tab-bar-icon-wrap.active {
  background-color: #f8e5e5;
}

.tab-bar-icon {
  font-size: 36rpx;
}

.tab-bar-text {
  font-size: 22rpx;
  color: #999;
}

.tab-bar-item.active .tab-bar-text {
  color: #B81F24;
}
