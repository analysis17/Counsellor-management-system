/* 换班申请详情页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
  background-color: #fff;
}

.header-left, .header-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-back-icon, .header-close-icon {
  font-size: 48rpx;
  color: #333;
}

.header-center {
  flex: 1;
  text-align: center;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 申请人信息卡片 */
.info-card {
  margin: 30rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
}

.applicant-header {
  display: flex;
  align-items: center;
}

.applicant-avatar {
  width: 96rpx;
  height: 96rpx;
  background-color: #B81F24;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.applicant-info {
  flex: 1;
}

.applicant-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.applicant-id {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
}

.applicant-college {
  font-size: 24rpx;
  color: #999;
}

.phone-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background-color: #07C160;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.phone-icon {
  font-size: 32rpx;
  color: #fff;
}

/* 换班申请信息卡片 */
.apply-card {
  margin: 0 30rpx 24rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.apply-info-item {
  display: flex;
  margin-bottom: 14rpx;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  width: 200rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

/* 换班理由卡片 */
.reason-card {
  margin: 0 30rpx 30rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
}

.reason-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部按钮 */
.bottom-btn {
  position: fixed;
  bottom: 0;
  left: 30rpx;
  right: 30rpx;
  margin-bottom: 30rpx;
  padding: 28rpx;
  background-color: #B81F24;
  border-radius: 40rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
