/* 辅导员换班申请页面样式 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 100rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 60rpx 30rpx 30rpx;
  background-color: #fff;
}

.header-left, .header-right {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-back-icon, .header-close-icon {
  font-size: 48rpx;
  color: #333;
}

.header-center {
  flex: 1;
  text-align: center;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* 搜索栏 */
.search-bar {
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  background-color: transparent;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-icon-wrap {
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-icon {
  position: relative;
  width: 150rpx;
  height: 150rpx;
}

.icon-letter {
  position: absolute;
  width: 100rpx;
  height: 80rpx;
  background-color: #e8e8e8;
  border-radius: 8rpx;
  top: 30rpx;
  left: 25rpx;
}

.icon-email {
  position: absolute;
  width: 60rpx;
  height: 50rpx;
  background-color: #B81F24;
  border-radius: 8rpx 8rpx 0 0;
  top: 40rpx;
  left: 55rpx;
  transform: rotate(-10deg);
}

.icon-dot {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  background-color: #409EFF;
  border-radius: 50%;
  top: 55rpx;
  left: 40rpx;
}

.icon-line {
  position: absolute;
  width: 80rpx;
  height: 4rpx;
  background-color: #333;
  top: 75rpx;
  left: 30rpx;
  transform: rotate(-15deg);
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 辅导员列表 */
.counselor-list {
  padding: 30rpx;
}

.counselor-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}

.counselor-header {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.counselor-avatar {
  width: 96rpx;
  height: 96rpx;
  background-color: #B81F24;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.counselor-info {
  flex: 1;
}

.counselor-name-row {
  display: flex;
  align-items: center;
}

.counselor-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-right: 12rpx;
}

.counselor-phone {
  font-size: 28rpx;
}

.counselor-id {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 6rpx;
}

.counselor-college {
  font-size: 24rpx;
  color: #999;
}

/* 值班信息 */
.duty-section {
  padding: 20rpx 0;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.duty-info-item {
  display: flex;
  margin-bottom: 12rpx;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  width: 180rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 24rpx;
  color: #333;
  flex: 1;
  word-break: break-all;
}

.duty-status {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.status-label {
  font-size: 24rpx;
  color: #999;
}

.status-value {
  font-size: 24rpx;
  font-weight: 500;
}

.status-onduty {
  color: #409EFF;
}

.status-pending {
  color: #67C23A;
}

/* 冲突提示 */
.conflict-bar {
  padding: 16rpx;
  background-color: #fef0f0;
  border-radius: 8rpx;
  margin-top: 16rpx;
  text-align: center;
}

.conflict-text {
  font-size: 24rpx;
  color: #F56C6C;
}

/* 卡片底部 */
.card-footer {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: right;
}

.btn-exchange {
  font-size: 26rpx;
  color: #B81F24;
}

/* 底部导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background-color: #fff;
  padding: 20rpx 0;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.tab-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-bar-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8rpx;
  border-radius: 12rpx;
}

.tab-bar-icon-wrap.active {
  background-color: #f8e5e5;
}

.tab-bar-icon {
  font-size: 36rpx;
}

.tab-bar-text {
  font-size: 22rpx;
  color: #999;
}

.tab-bar-item.active .tab-bar-text {
  color: #B81F24;
}

/* 换班申请卡片 */
.request-card {
  margin: 30rpx;
  padding: 30rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.request-header {
  display: flex;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.request-avatar {
  width: 96rpx;
  height: 96rpx;
  background-color: #B81F24;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.request-info {
  flex: 1;
}

.request-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.request-id {
  font-size: 26rpx;
  color: #666;
  display: block;
  margin-bottom: 6rpx;
}

.request-college {
  font-size: 24rpx;
  color: #999;
}

.request-duty {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.request-footer {
  padding-top: 20rpx;
  text-align: right;
}

.btn-agree {
  display: inline-block;
  padding: 12rpx 32rpx;
  background-color: #B81F24;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #fff;
}

.btn-agreed {
  background-color: #ccc;
}
